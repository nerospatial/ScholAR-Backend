# Database Configuration
DATABASE_URL=postgresql://postgres:1997@localhost:5432/scholar-db

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FRONTEND_URL=http://localhost:5173
REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Security Keys - Generate using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_64_character_hex_string_for_general_app_security
JWT_SECRET=your_64_character_hex_string_for_jwt_token_signing
SESSION_SECRET_KEY=your_64_character_hex_string_for_session_management


CODE_TTL_SECONDS=600
MAX_VERIFY_ATTEMPTS=3
MAX_RESEND_ATTEMPTS=3
RESEND_COOLDOWN_SECONDS=60


# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@scholar-glasses.com

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS Configuration (comma-separated for production)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Gemini API Key
GOOGLE_API_KEY=your_api_key_here

# Optional: Additional Services
# REDIS_CACHE=redis://localhost:6379
# OPUS_AUDIO=True

